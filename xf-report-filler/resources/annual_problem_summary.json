{
  "version": 1,
  "default_year_root": "E:\\文件夹\\1、工作\\2、产品，科技，联网检测\\1、产品监督\\26年",
  "output_file": "{year}年产品监督底册问题汇总.docx",
  "review_json_file": "{year}年产品监督底册问题汇总.review.json",
  "source_discovery": {
    "source_types": [
      {
        "type": "product_register_docx",
        "label": "新版产品巡查底册",
        "pattern": "**/*产品巡查底册*.docx",
        "priority": 1
      },
      {
        "type": "legacy_online_patrol_doc",
        "label": "旧版产品监督网上巡查",
        "pattern": "**/*产品监督网上巡查.doc",
        "priority": 3
      }
    ],
    "exclude_patterns": [
      "~$*",
      "*（*月档案）.doc",
      "*产品监督档案.doc"
    ],
    "ignore_prefixes": [
      "~$"
    ],
    "month_folder_pattern": "{month}月巡查",
    "duplicate_policy": "modified_version_first_then_newest",
    "modified_markers": [
      "修改版本",
      "修改版"
    ]
  },
  "brigade_order": [
    "梁溪大队",
    "锡山大队",
    "惠山大队",
    "滨湖大队",
    "新吴大队",
    "江阴大队",
    "宜兴大队",
    "经开大队"
  ],
  "yellow_problem_policy": {
    "include": true,
    "highlight_in_output": true,
    "review_note": "底册标黄，需人工复核。"
  },
  "text_policy": {
    "public_description": "before_parentheses_and_ps",
    "annual_summary_description": "keep_parentheses_and_ps",
    "normalize_parentheses": true,
    "keep_raw_detail_in_review_json": true
  },
  "word_style": {
    "title": "{year}年产品监督底册问题汇总",
    "visible_toc": false,
    "navigation_outline": "brigade_month",
    "body_layout": "case_then_issues",
    "include_images": false,
    "include_deduction_in_body": false,
    "title_font": "方正小标宋_GBK",
    "title_size_pt": 22,
    "heading_font": "方正黑体_GBK",
    "heading1_font": "方正黑体_GBK",
    "heading1_size_pt": 16,
    "heading2_font": "方正楷体_GBK",
    "heading2_size_pt": 16,
    "body_font": "方正仿宋_GBK",
    "fallback_body_font": "宋体",
    "body_size_pt": 16,
    "case_size_pt": 16,
    "page_width_cm": 21.0,
    "page_height_cm": 29.7,
    "top_margin_cm": 3.7,
    "bottom_margin_cm": 3.5,
    "left_margin_cm": 2.8,
    "right_margin_cm": 2.6,
    "lines_per_page": 22,
    "chars_per_line": 28,
    "line_pitch_twips": 580,
    "char_space_twips": 312,
    "yellow_highlight": "YELLOW"
  },
  "reference_docs": {
    "router": "references/annual_problem_summary/00_workflow_router.md",
    "source_product_register": "references/annual_problem_summary/source_product_register.md",
    "output_summary": "references/annual_problem_summary/output_annual_problem_summary.md",
    "validation_and_audit": "references/annual_problem_summary/validation_and_audit.md"
  }
}
